# Backend environment variables (Spring Boot)
# Copy this file to .env and export the vars before running,
# or set them directly in your shell / run config.

PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# PostgreSQL (matches docker-compose defaults)
PGHOST=localhost
PGPORT=5432
PGUSER=gotcherapp_app
PGPASSWORD=changeme_local
PGDATABASE=gotcherapp

# JWT — must be at least 32 characters for HS256; change in production
JWT_SECRET=change-me-to-a-long-random-secret-32c

# ─── SMTP / Email ─────────────────────────────────────────────────────────────
# Email features (verification, etc.) are silently disabled if SMTP_HOST is blank.
# Set these to enable outgoing email. Three options below:
#
# ── Option A: Gmail (App Password) ──────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password (select "Mail" / "Other")
# 4. Use the 16-character password as SMTP_PASSWORD
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# ── Option B: Resend (recommended for production) ───────────────────────────
# 1. Sign up at https://resend.com (free tier: 3,000 emails/month)
# 2. Add and verify your sending domain (or use their sandbox for testing)
# 3. Create an API key at https://resend.com/api-keys
# 4. Resend provides an SMTP relay — use these settings:
#
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx   ← your Resend API key
#
# ── Option C: Mailtrap (dev/testing only — emails never reach real inboxes) ─
# 1. Sign up at https://mailtrap.io (free tier available)
# 2. Go to Email Testing → Inboxes → your inbox → SMTP Settings
# 3. Copy the host/port/user/pass shown there
#
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USERNAME=<mailtrap-user>
# SMTP_PASSWORD=<mailtrap-pass>
#
# ── Active values (uncomment and fill in whichever option you chose) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Cookies ──────────────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS). Leave false for local HTTP dev.
SECURE_COOKIES=false
# SECURE_COOKIES=true   ← use this in production

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
# Sign up at https://cloudinary.com — free tier: 25GB storage + bandwidth
# Find these on your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
